# secrets.yaml — mismo archivo para TODOS los nodos del laboratorio.
# Va en la misma carpeta que am2315c-lab.yaml. NO subir a GitHub (agregar a .gitignore).
# Para un nodo nuevo: NO tocás este archivo. Solo cambiás device_name/friendly_name
# en am2315c-lab.yaml.

wifi_ssid: "NOMBRE_RED_LABORATORIO"
wifi_password: "clave_red_laboratorio"

# AP de emergencia si un nodo no logra conectar al WiFi del lab
fallback_ap_password: "elegir-una-clave"

# Cifrado de la API nativa ESPHome<->HA. Ya generada, compartida por todo
# el lab (válido para red cerrada de laboratorio, no expuesta a internet).
api_encryption_key: "GENERAR_UNA_VEZ_CON: python3 -c 'import os,base64;print(base64.b64encode(os.urandom(32)).decode())'"

# Password de OTA (reflashear por WiFi sin cable, mismo para todos los nodos)
ota_password: "elegir-una-clave"
